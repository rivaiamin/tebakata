# Public site URL for canonical links, Open Graph, and sitemap (no trailing slash)
PUBLIC_SITE_URL=https://your-domain.vercel.app

PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Daily AI generation (server-only)
LLM_API_KEY=
LLM_API_BASE_URL=https://api.openai.com/v1
LLM_API_MODEL=gpt-4o-mini
CRON_SECRET=very_long_random_secret
DAILY_WORD_TIME_ZONE=Asia/Jakarta

# Optional stock image provider for the winner reveal
UNSPLASH_ACCESS_KEY=your_unsplash_access_key
# or
PEXELS_API_KEY=your_pexels_api_key